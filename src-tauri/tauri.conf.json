{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kotonia-desktop",
  "version": "0.1.2",
  "identifier": "ai.kotonia.desktop",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "windows": [
      {
        "title": "kotonia",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$HOME/**",
            "$TEMP/**",
            "/tmp/**"
          ],
          "requireLiteralLeadingDot": false
        }
      }
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "shortDescription": "Kotonia local agent",
    "longDescription": "Tauri shell driving the kotonia-cli agent loop locally, with LLM inference served by kotonia.ai via the paired device token."
  }
}
