{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kotonia-desktop",
  "version": "0.1.0",
  "identifier": "ai.kotonia.desktop",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "windows": [
      {
        "title": "kotonia",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Kotonia local agent",
    "longDescription": "Tauri shell driving the kotonia-cli agent loop locally, with LLM inference served by kotonia.ai via the paired device token."
  }
}
